generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
  BUSINESS_OWNER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  PENDING_VERIFICATION
}

enum PostalCountry {
  DE
  TR
}

enum ForumTopicStatus {
  OPEN
  ANSWERED
  SOLVED
  LOCKED
  UNDER_REVIEW
}

enum EventStatus {
  DRAFT
  PENDING_APPROVAL
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum PriceType {
  FREE
  PAID
}

enum BusinessStatus {
  PENDING
  ACTIVE
  REJECTED
  SUSPENDED
}

enum VerificationStatus {
  UNVERIFIED
  PENDING_REVIEW
  VERIFIED
  REJECTED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

enum ReportTargetType {
  USER
  FORUM_TOPIC
  FORUM_REPLY
  EVENT
  BUSINESS
  BUSINESS_REVIEW
  MESSAGE
  JOB_POSTING
  COURIER_REQUEST
  USER_REVIEW
}

enum AttendeeStatus {
  GOING
  INTERESTED
}

enum PointAction {
  FORUM_TOPIC_CREATED
  FORUM_REPLY_CREATED
  FORUM_REPLY_MARKED_BEST
  EVENT_CREATED
  EVENT_JOINED
  EVENT_COMPLETED_ORGANIZER
  EVENT_COMPLETED_ATTENDEE
  USER_REVIEW_CREATED
}

enum ChatType {
  GLOBAL
  STATE
  CITY
  EVENT
  DIRECT
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  phone        String?
  passwordHash String?    @map("password_hash")
  googleId     String?    @unique @map("google_id")
  role         UserRole   @default(USER)
  status       UserStatus @default(ACTIVE)
  bannedUntil  DateTime?  @map("banned_until")
  emailVerified Boolean   @default(false) @map("email_verified")
  phoneVerified Boolean   @default(false) @map("phone_verified")
  twoFactorEnabled Boolean @default(false) @map("two_factor_enabled")
  twoFactorSecret  String? @map("two_factor_secret")
  gdprConsentAt DateTime? @map("gdpr_consent_at")
  expoPushToken String?   @map("expo_push_token")
  deletedAt    DateTime?  @map("deleted_at")
  referralCode String?    @unique @map("referral_code")
  referredById String?    @map("referred_by_id")
  points       Int        @default(0)
  level        Int        @default(1)
  lastLoginAt  DateTime?  @map("last_login_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  referredBy       User?  @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals        User[] @relation("UserReferrals")

  profile          Profile?
  forumTopics      ForumTopic[]
  forumReplies     ForumReply[]
  forumReplyVotes  ForumReplyVote[]
  events           Event[]           @relation("EventOrganizer")
  eventAttendees   EventAttendee[]
  businesses       Business[]
  businessReviews  BusinessReview[]
  reports          Report[]          @relation("Reporter")
  blocksInitiated  Block[]           @relation("Blocker")
  blocksReceived   Block[]           @relation("Blocked")
  auditLogs        AuditLog[]
  notifications    Notification[]
  chatMembers          ChatMember[]
  messages             Message[]
  forumInterests       ForumTopicInterest[]
  jobPostings          JobPosting[]
  courierRequests      CourierRequest[]
  courierAcceptances   CourierAcceptance[]
  travelAnnouncements  TravelAnnouncement[]
  travelRequests       TravelRequest[]
  subscription         Subscription?
  promoRedemptions     PromoCodeRedemption[]
  supportTickets       SupportTicket[]
  chatModerationLogs   ChatModerationLog[]
  passwordResetTokens    PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  pushSubscriptions      PushSubscription[]
  pollVotes              ForumPollVote[]
  messageReactions       MessageReaction[]
  pointLogs              PointLog[]
  reviewsWritten         UserReview[]      @relation("UserReviewAuthor")
  reviewsReceived        UserReview[]      @relation("UserReviewTarget")
  friendRequestsSent     FriendRequest[]   @relation("FriendRequestSender")
  friendRequestsReceived FriendRequest[]   @relation("FriendRequestReceiver")

  @@index([email])
  @@index([status])
  @@index([referredById])
  @@map("users")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@index([userId])
  @@map("push_subscriptions")
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("password_reset_tokens")
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique @map("user_id")
  displayName String   @map("display_name")
  firstName   String?  @map("first_name")
  lastName    String?  @map("last_name")
  avatarUrl   String?  @map("avatar_url")
  bio         String?
  stateId     String?  @map("state_id")
  cityId      String?  @map("city_id")
  languages   String[] @default([])
  interests   String[] @default([])
  userStatus  String?  @map("user_status")
  occupation  String?
  postalCode  String?  @map("postal_code")
  postalCountry PostalCountry @default(DE) @map("postal_country")
  allowedPages String[] @default([]) @map("allowed_pages")
  trustScore  Int      @default(0) @map("trust_score")
  dmEnabled   Boolean  @default(true) @map("dm_enabled")
  onboardingCompletedAt DateTime? @map("onboarding_completed_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  state FederalState? @relation(fields: [stateId], references: [id])
  city  City?         @relation(fields: [cityId], references: [id])

  @@map("profiles")
}

/// Kullanıcının kazandığı her puanın denetim kaydı — aynı olay için tekrar puan
/// verilmesini önlemek (idempotency) ve puan geçmişini göstermek için kullanılır.
model PointLog {
  id         String      @id @default(cuid())
  userId     String      @map("user_id")
  action     PointAction
  points     Int
  refType    String?     @map("ref_type")
  refId      String?     @map("ref_id")
  createdAt  DateTime    @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, action, refId])
  @@index([userId])
  @@map("point_logs")
}

/// Kullanıcıların birbirinin profiline bıraktığı puanlı yorum (referans/tavsiye niteliğinde).
model UserReview {
  id           String    @id @default(cuid())
  targetUserId String    @map("target_user_id")
  authorId     String    @map("author_id")
  rating       Int
  comment      String
  editCount    Int       @default(0) @map("edit_count")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  targetUser User @relation("UserReviewTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  author     User @relation("UserReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([targetUserId, authorId])
  @@index([targetUserId])
  @@map("user_reviews")
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

/// Kullanıcılar arası arkadaşlık isteği/ilişkisi. Kabul edilince ilişki kaydı silinmez, status ACCEPTED olarak tutulur.
model FriendRequest {
  id         String              @id @default(cuid())
  senderId   String              @map("sender_id")
  receiverId String              @map("receiver_id")
  status     FriendRequestStatus @default(PENDING)
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")

  sender   User @relation("FriendRequestSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("FriendRequestReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([receiverId, status])
  @@index([senderId, status])
  @@map("friend_requests")
}

model FederalState {
  id        String   @id @default(cuid())
  name      String
  nameDe    String   @map("name_de")
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  cities   City[]
  profiles Profile[]
  topics   ForumTopic[]
  events   Event[]
  businesses Business[]
  chats    Chat[]
  jobs     JobPosting[]

  @@map("federal_states")
}

model City {
  id        String   @id @default(cuid())
  stateId   String   @map("state_id")
  name      String
  slug      String
  createdAt DateTime @default(now()) @map("created_at")

  state      FederalState @relation(fields: [stateId], references: [id], onDelete: Cascade)
  profiles   Profile[]
  topics     ForumTopic[]
  events     Event[]
  businesses Business[]
  chats      Chat[]
  jobs       JobPosting[]

  @@unique([stateId, slug])
  @@index([stateId])
  @@map("cities")
}

model TopicCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  topics ForumTopic[]

  @@map("topic_categories")
}

model ForumTopic {
  id            String           @id @default(cuid())
  userId        String           @map("user_id")
  categoryId    String           @map("category_id")
  stateId       String?          @map("state_id")
  cityId        String?          @map("city_id")
  title         String
  body          String
  status        ForumTopicStatus @default(OPEN)
  isAnonymous   Boolean          @default(false) @map("is_anonymous")
  solvedReplyId String?          @unique @map("solved_reply_id")
  viewCount     Int              @default(0) @map("view_count")
  deletedAt     DateTime?        @map("deleted_at")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  user     User          @relation(fields: [userId], references: [id])
  category TopicCategory @relation(fields: [categoryId], references: [id])
  state    FederalState? @relation(fields: [stateId], references: [id])
  city     City?         @relation(fields: [cityId], references: [id])
  replies  ForumReply[]
  solvedReply ForumReply? @relation("SolvedReply", fields: [solvedReplyId], references: [id])
  interests ForumTopicInterest[]
  poll      ForumPoll?

  @@index([categoryId])
  @@index([stateId, cityId])
  @@index([status])
  @@index([createdAt])
  @@map("forum_topics")
}

model ForumPoll {
  id        String          @id @default(cuid())
  topicId   String          @unique @map("topic_id")
  question  String
  endsAt    DateTime?       @map("ends_at")
  createdAt DateTime        @default(now()) @map("created_at")

  topic   ForumTopic       @relation(fields: [topicId], references: [id], onDelete: Cascade)
  options ForumPollOption[]

  @@map("forum_polls")
}

model ForumPollOption {
  id     String @id @default(cuid())
  pollId String @map("poll_id")
  text   String
  order  Int    @default(0)

  poll  ForumPoll      @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes ForumPollVote[]

  @@index([pollId])
  @@map("forum_poll_options")
}

model ForumPollVote {
  id       String @id @default(cuid())
  optionId String @map("option_id")
  userId   String @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  option ForumPollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([optionId, userId])
  @@index([userId])
  @@map("forum_poll_votes")
}

model ForumTopicInterest {
  id        String   @id @default(cuid())
  topicId   String   @map("topic_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  topic ForumTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([topicId, userId])
  @@index([topicId])
  @@map("forum_topic_interests")
}

model ForumReply {
  id        String    @id @default(cuid())
  topicId   String    @map("topic_id")
  userId    String    @map("user_id")
  parentId  String?   @map("parent_id")
  body      String
  isBest    Boolean   @default(false) @map("is_best")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  topic       ForumTopic       @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id])
  parent      ForumReply?      @relation("ReplyThread", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children    ForumReply[]     @relation("ReplyThread")
  votes       ForumReplyVote[]
  solvedTopic ForumTopic?      @relation("SolvedReply")

  @@index([topicId])
  @@map("forum_replies")
}

model ForumReplyVote {
  id        String   @id @default(cuid())
  replyId   String   @map("reply_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  reply ForumReply @relation(fields: [replyId], references: [id], onDelete: Cascade)
  user  User       @relation(fields: [userId], references: [id])

  @@unique([replyId, userId])
  @@map("forum_reply_votes")
}

model Event {
  id          String      @id @default(cuid())
  organizerId String      @map("organizer_id")
  stateId     String      @map("state_id")
  cityId      String      @map("city_id")
  title       String
  description String
  location    String
  latitude    Float?
  longitude   Float?
  startsAt    DateTime    @map("starts_at")
  endsAt      DateTime?   @map("ends_at")
  capacity    Int?
  priceType   PriceType   @default(FREE) @map("price_type")
  priceAmount Float?      @map("price_amount")
  category    String?
  status      EventStatus @default(PENDING_APPROVAL)
  deletedAt   DateTime?   @map("deleted_at")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  organizer User         @relation("EventOrganizer", fields: [organizerId], references: [id])
  state     FederalState @relation(fields: [stateId], references: [id])
  city      City         @relation(fields: [cityId], references: [id])
  attendees EventAttendee[]
  chats     Chat[]

  @@index([stateId, cityId])
  @@index([startsAt])
  @@index([status])
  @@map("events")
}

model EventAttendee {
  id        String         @id @default(cuid())
  eventId   String         @map("event_id")
  userId    String         @map("user_id")
  status    AttendeeStatus @default(GOING)
  createdAt DateTime       @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@map("event_attendees")
}

model BusinessCategory {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  businesses Business[]

  @@map("business_categories")
}

model Business {
  id              String         @id @default(cuid())
  ownerId         String?        @map("owner_id")
  categoryId      String         @map("category_id")
  stateId         String         @map("state_id")
  cityId          String         @map("city_id")
  name            String
  description     String
  address         String?
  latitude        Float?
  longitude       Float?
  verificationStatus VerificationStatus @default(UNVERIFIED) @map("verification_status")
  verificationDocs   String[]           @default([]) @map("verification_docs")
  verificationNote   String?            @map("verification_note")
  phone           String?
  whatsapp        String?
  website         String?
  languages       String[]       @default([])
  speaksTurkish   Boolean        @default(true) @map("speaks_turkish")
  isVerified      Boolean        @default(false) @map("is_verified")
  status          BusinessStatus @default(PENDING)
  averageRating   Float          @default(0) @map("average_rating")
  reviewCount     Int            @default(0) @map("review_count")
  searchCount     Int            @default(0) @map("search_count")
  deletedAt       DateTime?      @map("deleted_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  owner    User?            @relation(fields: [ownerId], references: [id])
  category BusinessCategory @relation(fields: [categoryId], references: [id])
  state    FederalState     @relation(fields: [stateId], references: [id])
  city     City             @relation(fields: [cityId], references: [id])
  reviews  BusinessReview[]

  @@index([stateId, cityId])
  @@index([categoryId])
  @@index([status])
  @@map("businesses")
}

model BusinessReview {
  id         String    @id @default(cuid())
  businessId String    @map("business_id")
  userId     String    @map("user_id")
  rating     Int
  comment    String?
  status     ReviewStatus @default(APPROVED)
  editCount  Int          @default(0) @map("edit_count")
  deletedAt  DateTime?    @map("deleted_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@unique([businessId, userId])
  @@map("business_reviews")
}

model Chat {
  id        String   @id @default(cuid())
  type      ChatType
  name      String?
  password  String?
  stateId   String?  @map("state_id")
  cityId    String?  @map("city_id")
  eventId   String?  @map("event_id")
  isPublic  Boolean  @default(true) @map("is_public")
  createdAt DateTime @default(now()) @map("created_at")

  state            FederalState?         @relation(fields: [stateId], references: [id])
  city             City?                 @relation(fields: [cityId], references: [id])
  event            Event?                @relation(fields: [eventId], references: [id])
  members          ChatMember[]
  messages         Message[]
  moderationLogs   ChatModerationLog[]

  @@map("chats")
}

model ChatMember {
  id          String    @id @default(cuid())
  chatId      String    @map("chat_id")
  userId      String    @map("user_id")
  joinedAt    DateTime  @default(now()) @map("joined_at")
  lastReadAt  DateTime? @map("last_read_at")
  hiddenAt    DateTime? @map("hidden_at")
  mutedUntil  DateTime? @map("muted_until")

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@map("chat_members")
}

model Message {
  id          String    @id @default(cuid())
  chatId      String    @map("chat_id")
  userId      String    @map("user_id")
  body        String
  attachments Json?     @default("[]")
  replyToId   String?   @map("reply_to_id")
  expiresAt   DateTime? @map("expires_at")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  chat      Chat             @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id])
  reactions MessageReaction[]
  replyTo   Message?         @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   Message[]        @relation("MessageReplies")

  @@index([chatId, createdAt])
  @@index([replyToId])
  @@map("messages")
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  emoji     String   @db.VarChar(8)
  createdAt DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("message_reactions")
}

model Report {
  id           String           @id @default(cuid())
  reporterId   String           @map("reporter_id")
  targetType   ReportTargetType @map("target_type")
  targetId     String           @map("target_id")
  reason       String
  details      String?
  status       ReportStatus     @default(PENDING)
  moderatorId  String?          @map("moderator_id")
  createdAt    DateTime         @default(now()) @map("created_at")
  resolvedAt   DateTime?        @map("resolved_at")

  reporter User @relation("Reporter", fields: [reporterId], references: [id])

  @@index([status])
  @@index([targetType, targetId])
  @@map("reports")
}

model Block {
  id        String   @id @default(cuid())
  blockerId String   @map("blocker_id")
  blockedId String   @map("blocked_id")
  createdAt DateTime @default(now()) @map("created_at")

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@map("blocks")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  title     String
  body      String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@map("audit_logs")
}

enum JobListingType {
  EMPLOYER
  SEEKER
}

enum JobType {
  FULL_TIME
  PART_TIME
  MINIJOB
  AUSBILDUNG
  INTERNSHIP
  FREELANCE
}

enum WorkMode {
  ONSITE
  REMOTE
  HYBRID
}

enum JobStatus {
  PENDING
  PUBLISHED
  CLOSED
  EXPIRED
  REJECTED
}

enum ContactMethod {
  PLATFORM
  EMAIL
  EXTERNAL_URL
}

model JobPosting {
  id              String          @id @default(cuid())
  ownerId         String          @map("owner_id")
  listingType     JobListingType  @default(EMPLOYER) @map("listing_type")
  stateId         String?         @map("state_id")
  cityId          String?         @map("city_id")
  company         String?
  title           String
  description     String
  briefInfo       String?         @map("brief_info")
  cvUrl           String?         @map("cv_url")
  cvFileName      String?         @map("cv_file_name")
  category        String
  jobType         JobType         @map("job_type")
  workMode        WorkMode        @default(ONSITE) @map("work_mode")
  salaryRange     String?         @map("salary_range")
  turkishFriendly Boolean         @default(false) @map("turkish_friendly")
  germanLevel     String?         @map("german_level")
  contactMethod   ContactMethod   @default(PLATFORM) @map("contact_method")
  contactValue    String?         @map("contact_value")
  status          JobStatus       @default(PENDING)
  viewCount       Int             @default(0) @map("view_count")
  expiresAt       DateTime?       @map("expires_at")
  deletedAt       DateTime?       @map("deleted_at")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  owner User          @relation(fields: [ownerId], references: [id])
  state FederalState? @relation(fields: [stateId], references: [id])
  city  City?         @relation(fields: [cityId], references: [id])

  @@index([status])
  @@index([cityId])
  @@index([jobType])
  @@index([listingType])
  @@map("job_postings")
}

enum CourierDirection {
  DE_TO_TR
  TR_TO_DE
}

enum CourierPaymentType {
  FREE
  PAID
  NEGOTIABLE
}

enum CourierStatus {
  OPEN
  MATCHED
  COMPLETED
  CANCELLED
  EXPIRED
}

enum CourierAcceptanceStatus {
  PENDING
  CONFIRMED
  DECLINED
  CANCELLED
}

model CourierRequest {
  id                String             @id @default(cuid())
  ownerId           String             @map("owner_id")
  direction         CourierDirection
  fromArea          String             @map("from_area")
  toArea            String             @map("to_area")
  itemName          String             @map("item_name")
  itemCategory      String             @map("item_category")
  weightKg          Float?             @map("weight_kg")
  estimatedValueEur Float?             @map("estimated_value_eur")
  paymentType       CourierPaymentType @default(NEGOTIABLE) @map("payment_type")
  paymentAmount     Float?             @map("payment_amount")
  notes             String?
  preferredDate     DateTime?          @map("preferred_date")
  status            CourierStatus      @default(OPEN)
  confirmedAcceptanceId String?        @unique @map("confirmed_acceptance_id")
  deletedAt         DateTime?          @map("deleted_at")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  owner       User                @relation(fields: [ownerId], references: [id])
  acceptances CourierAcceptance[] @relation("RequestAcceptances")
  confirmed   CourierAcceptance?  @relation("ConfirmedAcceptance", fields: [confirmedAcceptanceId], references: [id])

  @@index([status, direction])
  @@map("courier_requests")
}

model CourierAcceptance {
  id         String                  @id @default(cuid())
  requestId  String                  @map("request_id")
  travelerId String                  @map("traveler_id")
  message    String?
  travelDate DateTime?               @map("travel_date")
  status     CourierAcceptanceStatus @default(PENDING)
  createdAt  DateTime                @default(now()) @map("created_at")
  updatedAt  DateTime                @updatedAt @map("updated_at")

  request           CourierRequest @relation("RequestAcceptances", fields: [requestId], references: [id], onDelete: Cascade)
  traveler          User           @relation(fields: [travelerId], references: [id])
  confirmedRequest  CourierRequest? @relation("ConfirmedAcceptance")

  @@unique([requestId, travelerId])
  @@index([travelerId])
  @@map("courier_acceptances")
}

// ── Travel Announcements ─────────────────────────────────────────────────────

enum TravelStatus {
  OPEN
  CLOSED
  EXPIRED
}

enum TravelRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
}

model TravelAnnouncement {
  id            String       @id @default(cuid())
  userId        String       @map("user_id")
  direction     CourierDirection
  fromCity      String       @map("from_city")
  toCity        String       @map("to_city")
  departureDate DateTime     @map("departure_date")
  availableKg   Float?       @map("available_kg")
  notes         String?
  status        TravelStatus @default(OPEN)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  user     User            @relation(fields: [userId], references: [id])
  requests TravelRequest[]

  @@index([userId])
  @@index([direction])
  @@index([departureDate])
  @@map("travel_announcements")
}

model TravelRequest {
  id             String              @id @default(cuid())
  announcementId String              @map("announcement_id")
  requesterId    String              @map("requester_id")
  itemName       String              @map("item_name")
  description    String?
  weightKg       Float?              @map("weight_kg")
  paymentType    CourierPaymentType  @default(NEGOTIABLE) @map("payment_type")
  paymentAmount  Float?              @map("payment_amount")
  notes          String?
  status         TravelRequestStatus @default(PENDING)
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  announcement TravelAnnouncement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  requester    User               @relation(fields: [requesterId], references: [id])

  @@unique([announcementId, requesterId])
  @@index([announcementId])
  @@index([requesterId])
  @@map("travel_requests")
}

// ── Membership ───────────────────────────────────────────────────────────────

enum MembershipPlan {
  USER_YEARLY
  BUSINESS_YEARLY
  FREE_PROMO
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING_PAYMENT
}

enum PromoDiscountType {
  FREE
  PERCENT
}

model PromoCode {
  id              String            @id @default(cuid())
  code            String            @unique
  label           String
  maxUses         Int               @map("max_uses")
  usedCount       Int               @default(0) @map("used_count")
  plan            MembershipPlan
  discountType    PromoDiscountType @default(FREE) @map("discount_type")
  discountPercent Float?            @map("discount_percent")
  validUntil      DateTime?         @map("valid_until")
  active          Boolean           @default(true)
  createdAt       DateTime          @default(now()) @map("created_at")

  redemptions   PromoCodeRedemption[]
  subscriptions Subscription[]

  @@index([code])
  @@map("promo_codes")
}

model PromoCodeRedemption {
  id          String   @id @default(cuid())
  promoCodeId String   @map("promo_code_id")
  userId      String   @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([userId])
  @@map("promo_code_redemptions")
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique @map("user_id")
  plan                 MembershipPlan
  status               SubscriptionStatus @default(ACTIVE)
  startsAt             DateTime           @default(now()) @map("starts_at")
  expiresAt            DateTime?          @map("expires_at")
  promoCodeId          String?            @map("promo_code_id")
  stripeCustomerId     String?            @map("stripe_customer_id")
  stripeSubscriptionId String?            @map("stripe_subscription_id")
  cancelledAt          DateTime?          @map("cancelled_at")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  promoCode PromoCode? @relation(fields: [promoCodeId], references: [id])

  @@index([userId, status])
  @@map("subscriptions")
}

enum SupportCategory {
  TECHNICAL
  SUGGESTION
  REQUEST
  COMPLAINT
  OTHER
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model SupportTicket {
  id         String              @id @default(cuid())
  userId     String              @map("user_id")
  category   SupportCategory
  subject    String
  message    String
  status     SupportTicketStatus @default(OPEN)
  adminNote  String?             @map("admin_note")
  resolvedAt DateTime?           @map("resolved_at")
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([category])
  @@index([createdAt])
  @@map("support_tickets")
}

enum ChatBannedWordSeverity {
  CRITICAL
  WARNING
}

enum ChatModerationReason {
  BANNED_WORD
  SOCIAL_MEDIA
  PHONE_NUMBER
  SPAM
  RATE_LIMIT
}

model ChatBannedWord {
  id        String                 @id @default(cuid())
  word      String                 @unique
  severity  ChatBannedWordSeverity @default(CRITICAL)
  isActive  Boolean                @default(true) @map("is_active")
  createdAt DateTime               @default(now()) @map("created_at")

  @@map("chat_banned_words")
}

model ChatModerationLog {
  id             String               @id @default(cuid())
  userId         String               @map("user_id")
  chatId         String?              @map("chat_id")
  reason         ChatModerationReason
  detail         String?
  messageSnippet String?              @map("message_snippet")
  autoBanned     Boolean              @default(false) @map("auto_banned")
  bannedUntil    DateTime?            @map("banned_until")
  createdAt      DateTime             @default(now()) @map("created_at")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  chat Chat? @relation(fields: [chatId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("chat_moderation_logs")
}

