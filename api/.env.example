DATABASE_URL="postgresql://turkexpatlar:turkexpatlar_dev@localhost:5432/turkexpatlar?schema=public"
JWT_SECRET="change-me-in-production-use-long-random-string"
JWT_EXPIRES_IN="7d"
PORT=3201
CORS_ORIGIN="http://localhost:3200"
WEB_URL="http://localhost:3200"

# Stripe (ödeme sistemi) — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_PLACEHOLDER"
STRIPE_WEBHOOK_SECRET="whsec_PLACEHOLDER"

# E-posta (şifremi unuttum) — SMTP ayarları
# Boş bırakılırsa development modunda reset linki konsola yazdırılır
SITE_URL="http://localhost:3200"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="noreply@turkexpatlar.de"
SMTP_FROM_NAME="Türk Expatlar"

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Production API base URL (OAuth callback için; web değil)
API_URL=https://api.turkexpatlar.de

# Web Push VAPID — kendi anahtarınızı üretin: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=PLACEHOLDER_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=PLACEHOLDER_VAPID_PRIVATE_KEY
VAPID_EMAIL=mailto:admin@turkexpatlar.de

# Sentry (opsiyonel — boş bırakılırsa hata izleme devre dışı)
SENTRY_DSN=

# OpenAI (forum cevap botu) — https://platform.openai.com/api-keys
# Boş bırakılırsa bot, anahtar kelime tabanlı sabit cevap bankasına düşer
OPENAI_API_KEY=
OPENAI_MODEL="gpt-4.1-mini"
