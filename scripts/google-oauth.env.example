# Google OAuth — https://console.cloud.google.com/apis/credentials
# Bu dosyayı google-oauth.env olarak kopyalayın (proje kökünde, gitignore'da)

GOOGLE_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxx

# Google Cloud Console ayarları:
# - OAuth consent screen: External, turkexpatlar.de
# - Authorized JavaScript origins:
#     https://turkexpatlar.de
#     https://api.turkexpatlar.de
# - Authorized redirect URIs:
#     https://api.turkexpatlar.de/api/auth/google/callback
