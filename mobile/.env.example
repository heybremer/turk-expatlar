# Mobile (Expo) ortam değişkenleri — kopyalayıp .env yapın
# Expo, EXPO_PUBLIC_ önekli değişkenleri otomatik olarak process.env üzerinden expose eder.

# API base URL. Boş bırakılırsa production API'ye (https://api.turkexpatlar.de/api) bağlanır.
# Yerel geliştirme için örn: http://192.168.1.10:3201/api (localhost, cihazdan erişilemeyeceği için IP kullanın)
EXPO_PUBLIC_API_URL=
