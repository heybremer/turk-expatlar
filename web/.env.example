# Web (Next.js) ortam değişkenleri — kopyalayıp .env.local yapın

# API'nin herkese açık base URL'i (tarayıcıdan erişilebilir olmalı)
NEXT_PUBLIC_API_URL="http://localhost:3201"

# Sitemap/robots.txt için sitenin herkese açık URL'i
NEXT_PUBLIC_SITE_URL="http://localhost:3200"

# Yüklenen dosyalar için CDN/asset host (opsiyonel)
NEXT_PUBLIC_CDN_HOST=

# api/.env içindeki JWT_SECRET ile AYNI değer olmalı (middleware token doğrulaması için)
JWT_SECRET="change-me-in-production-use-long-random-string"

# Sentry (opsiyonel — boş bırakılırsa hata izleme devre dışı)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
